# Local backend port (Hono API)
PORT=3000

# Local frontend port (Vite dev server)
CLIENT_PORT=5173

# Frontend proxy target for /api in local dev.
# By default this can match PORT.
API_PORT=3000

# Optional explicit API proxy target (overrides API_PORT), for example:
# API_TARGET=http://127.0.0.1:4000

# Optional database path. Defaults to ./crunchtime.db
# DB_PATH=crunchtime.db

# Optional Cloudflare team domain for auth in production-like mode.
# Leave empty for local dev auth bypass.
# CF_TEAM_DOMAIN=
